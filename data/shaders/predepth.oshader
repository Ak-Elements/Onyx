#version 460 core

#include "includes/common.h"
#include "includes/viewconstants.h"

vertex
{
    layout (location = 0) in vec4 inPosition;
    layout (location = 1) in vec4 inNormal;

    void main()
    {
        gl_Position = u_ViewConstants.ProjectionMatrix * u_ViewConstants.ViewMatrix * vec4(inPosition.xyz, 1.0);
    }
}

fragment
{
    void main()
    {
    }
}