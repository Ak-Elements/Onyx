component FreeCameraControllerComponent
{
    float32 BaseVelocity = 0.15
    float32 MinVelocity = 0.001
    float32 MaxVelocity = 0.5

    float32 RotationVelocity = 0.3
    float32 VelocityIncrementFactor = 0.3
}

[Transient, Hidden]
component FreeCameraRuntimeComponent
{
    Vector3f32 InputDirection
    Vector3f32 InputRotation

    float32 Velocity = 0.0

    float32 Pitch = 0.0
    float32 Yaw = 0.0

    float32 PitchDelta = 0.0
    float32 YawDelta = 0.0
}
