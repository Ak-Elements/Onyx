component FreeCameraControllerComponent
{
    float32 Speed = 0.2
    float32 RotationSpeed = 0.3
}

[Transient, Hidden]
component FreeCameraRuntimeComponent
{
    Vector3f32 InputDirection
    Vector3f32 InputRotation

    int32_t SpeedStep = 0
    float32 Pitch = 0.0
    float32 Yaw = 0.0

    float32 PitchDelta = 0.0
    float32 YawDelta = 0.0
}
